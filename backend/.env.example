# WithoutBorder — Backend environment variables
# Copy to .env and customize

DATABASE_URL=postgresql+asyncpg://wb_user:wb_password@localhost:5432/withoutborder

# ── Keycloak / OIDC ───────────────────────────────────────────────────────
KEYCLOAK_URL=https://auth.manga-pics.com
KEYCLOAK_REALM=without-border
KEYCLOAK_AUDIENCE=without-border-frontend
KEYCLOAK_VERIFY_AUD=true
KEYCLOAK_JWKS_CACHE_TTL=3600

# ── Legacy JWT (kept for compatibility, not used with Keycloak) ────────────
SECRET_KEY=your-super-secret-key-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# LLM — Gemma 4
LLM_PROVIDER=ollama
# or: vertexai
LLM_MODEL=gemma4:9b
# or: gemma4:27b
OLLAMA_BASE_URL=http://localhost:11434

# Vertex AI (alternative to Ollama)
# LLM_PROVIDER=vertexai
# VERTEXAI_PROJECT=your-gcp-project-id
# VERTEXAI_LOCATION=us-central1

# File uploads
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=20

# CORS
ALLOWED_ORIGINS=["http://localhost:4200"]

# Dev options
AUTO_SEED=true
# ── Auth bypass (LOCAL DEV ONLY) ─────────────────────────────────────────
# Set AUTH_DISABLED=true to skip Keycloak authentication entirely.
# NEVER enable in production. Both backend and frontend must be aligned.
AUTH_DISABLED=false
# optional: specific user UUID to impersonate when auth is off
AUTH_DISABLED_USER_ID=
