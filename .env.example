# =============================================================================
# Without Border — Production Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values before deploying.
# Never commit the real .env file to version control.
# =============================================================================

# Domain & Traefik
DOMAIN=wb.canadaquebec.ca
TRAEFIK_TLS=true
TRAEFIK_CERT_RESOLVER=myhttpchallenge

# LLM / Ollama
LLM_MODEL=gemma4
OLLAMA_BASE_URL=http://ollama:11434

# Keycloak / OIDC
KEYCLOAK_URL=https://auth.manga-pics.com
KEYCLOAK_REALM=without-border
KEYCLOAK_AUDIENCE=without-border-frontend
KEYCLOAK_VERIFY_AUD=true

# Database
POSTGRES_DB=withoutborder
POSTGRES_USER=wb_user
POSTGRES_PASSWORD=change_me_in_production
DATABASE_URL=postgresql+asyncpg://wb_user:change_me_in_production@postgres:5432/withoutborder

# CORS
ALLOWED_ORIGINS=["https://wb.canadaquebec.ca"]

# Auth
AUTH_DISABLED=false
AUTH_DISABLED_USER_ID=
SECRET_KEY=change_me_min_32_chars

# App settings
AUTO_SEED=false
