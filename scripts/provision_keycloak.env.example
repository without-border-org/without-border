# ── Keycloak provisioning — copy to provision_keycloak.env and fill in secrets ─
# This file is NOT committed to git.

KEYCLOAK_URL=https://auth.manga-pics.com
KEYCLOAK_REALM=without-border

# Keycloak admin credentials (master realm admin)
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=

# Password assigned to all demo accounts
DEMO_PASSWORD=demo1234
